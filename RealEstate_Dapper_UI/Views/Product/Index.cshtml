@model List<ResultProductDto>
    @{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Admin/Index.cshtml";
    int counter = 0;
}

<div class="container-fluid pt-4 px-4">
    <div class="row g-4">
        <div class="col-12">
            <div class="bg-light rounded h-100 p-4">
                <h6 class="mb-4">Product Table</h6>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th scope="col">#</th>
                                <th scope="col">Title</th>
                                <th scope="col">Price</th>
                                <th scope="col">Cover Image</th>
                                <th scope="col">City</th>
                                <th scope="col">District</th>
                                <th scope="col">Address</th>
                                <th scope="col">Type</th>
                                <th scope="col">Category Name</th>
                                <th scope="col">Delete</th>
                                <th scope="col">Update</th>
                                <th scope="col">Look on the website</th>
                                <th scope="col">Deals of the Day</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                counter++;
                                <tr>
                                    <th scope="row">@counter</th>
                                    <td>@item.Title</td>
                                    <td>@item.Price</td>
                                    <td>@item.CoverImage</td>
                                    <td>@item.City</td>
                                    <td>@item.District</td>
                                    <td>@item.Address</td>
                                    <td>@item.Type</td>
                                    <td>@item.CategoryName</td>
                                    <td><a href="/Product/DeleteProduct/@item.ProductID" class="btn btn-outline-danger">Delete</a></td>
                                    <td><a href="/Product/UpdateProduct/@item.ProductID" class="btn btn-outline-success">Update</a></td>
                                    <td><a href="/Product/ProductDetail/@item.ProductID" class="btn btn-outline-primary">Look on the website</a></td>
                                    <td>
                                        @if (item.DealOfTheDay==true)
                                        {
                                            <a href="/Product/DeactivateDealOfTheDay/@item.ProductID" class="btn btn-outline-secondary">Deactivate</a>
                                        }
                                        else if(item.DealOfTheDay==false)
                                        {
                                            <a href="/Product/ActivateDealOfTheDay/@item.ProductID" class="btn btn-outline-warning">Activate</a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <a href="/Product/CreateProduct" class="btn btn-outline-info">Enter a new Product</a>
                </div>
            </div>
        </div>
    </div>
</div>div>
</div>