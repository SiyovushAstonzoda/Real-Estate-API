@{
    ViewData["Title"] = "PropertySingle";
    Layout = "~/Views/Shared/_DefaultLayout.cshtml";
}

<section class="w3l-about-breadcrumb">
    <div class="breadcrumb-bg breadcrumb-bg-about pt-5">
        <div class="container pt-lg-5 py-3">
        </div>
    </div>
</section>
<section class="w3l-breadcrumb">
    <div class="container">
        <ul class="breadcrumbs-custom-path">
            <li><a href="/Default/Index/">Home</a></li>
            <li class="active"><span class="fa fa-angle-right mx-2" aria-hidden="true"></span> Property</li>
            <li class="active"><span class="fa fa-angle-right mx-2" aria-hidden="true"></span> property single</li>@*Product Details*@
        </ul>
    </div>
</section>
<!--/blog-post-->
<section class="w3l-blog post-content py-5">
    <div class="container py-lg-4 py-md-3 py-2">

        <div class="inner mb-4">
            <ul class="blog-single-author-date align-items-center">
                <li>
                    <div class="listing-category"><span>@ViewBag.Type</span></div>
                </li>
                <li><span class="fa fa-clock-o"></span>@ViewBag.AnnouncementDate months ago</li>
                <li><span class="fa fa-eye"></span> 250 views</li>
            </ul>
        </div>
    
        <div class="post-content">
            <h2 class="title-single">@ViewBag.ProductTitle</h2>
        </div>
    
        <div class="blo-singl mb-4">
            <ul class="blog-single-author-date align-items-center">
                <li>
                    <p>@ViewBag.Address</p>
                </li>
                <li><span class="fa fa-bed"></span>@ViewBag.BedRoomCount Beds</li>
                <li><span class="fa fa-bath"></span>@ViewBag.BathCount Baths</li>
                <li><span class="fa fa-share-square-o"></span>@ViewBag.ProductSize sqrft</li>
            </ul>
            <ul class="share-post">
                <a href="#url" class="cost-estate m-o">@ViewBag.Price</a>
            </ul>
        </div>
    
        <div class="row">

            <div class="col-lg-8 w3l-news">
                <div class="blog-single-post">

                    @await Component.InvokeAsync("_PropertySliderComponentPartial");

                    <div class="single-post-content">
                        <h3 class="post-content-title mb-3">Description</h3>
                        <p class="mb-4">
                            @ViewBag.Description    
                        </p>
                        <div class="single-bg-white">
                            <h3 class="post-content-title mb-4">Property detail</h3>
                            <ul class="details-list">
                                <li><strong>Property id :</strong> @ViewBag.ProductDetailID </li>
                                <li><strong>Property size :</strong> @ViewBag.ProductSize sqft </li>
                                <li><strong>Rooms :</strong> @ViewBag.RoomCount </li>
                                <li><strong>Bedrooms :</strong> @ViewBag.BedRoomCount </li>
                                <li><strong>Bathrooms :</strong> @ViewBag.BathCount </li>
                                @* <li><strong>Exterior material :</strong> Brick </li> *@
                                @* <li><strong>Structure type :</strong> Wood </li> *@
                                <li><strong>Garage size :</strong> @ViewBag.GarageSize cars </li>
                                @* <li><strong>Garages :</strong> 15 </li> *@
                                <li><strong>Property Price :</strong> $ @ViewBag.Price </li>
                                <li><strong>Built Year :</strong> @ViewBag.BuildYear </li>
                                <li><strong>Posted on :</strong> @ViewBag.PostedOn </li>
                            </ul>
                        </div>
                        
                       @await Component.InvokeAsync("_PropertyAmenityStatusTrueByIdComponentPartial");

                    </div>

                    <div class="single-bg-white">
                        <h3 class="post-content-title mb-4">Location</h3>
                        <div class="agent-map">
                            <iframe src="@ViewBag.Location"></iframe>
                        </div>
                    </div>

                    <div class="single-bg-white mb-0">
                        <h3 class="post-content-title mb-4">Video</h3>
                        <div class="post-content">
                            <iframe src="https://www.youtube.com/embed/@ViewBag.VideoUrl" frameborder="0"
                                allowfullscreen=""></iframe>
                        </div>
                    </div>
                </div>
            </div>
        
            @await Component.InvokeAsync("_PropertyAppUserComponentPartial");
        
        </div>
    </div>
</section>
<!--//blog-posts-->