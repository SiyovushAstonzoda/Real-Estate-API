@model CreateEmployeeDto
@{
    ViewData["Title"] = "CreateEmployee";
    Layout = "~/Views/Admin/Index.cshtml";
}

<h1>@ViewData["Title"]</h1>

<div class="bg-light rounded h-100 p-4">
    <form method="post">
        <label>Name</label>
        <input type="text" asp-for="Name" class="form-control" />
        <br />
        <label>Title</label>
        <input type="text" asp-for="Title" class="form-control" />
        <br />
        <label>Mail</label>
        <input type="text" asp-for="Mail" class="form-control" />
        <br />
        <label>PhoneNumber</label>
        <input type="text" asp-for="PhoneNumber" class="form-control" />
        <br />
        <label>Image Url</label>
        <input type="text" asp-for="ImageUrl" class="form-control" />
        <br />
        <label>Status</label>
        <input type="Status" asp-for="ImageUrl" class="form-control" />
        <br />
        <button class="btn btn-primary">Add Employee</button>
    </form>
</div>
</div>
</div>
</div>