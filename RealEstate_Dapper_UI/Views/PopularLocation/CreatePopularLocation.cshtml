@model CreatePopularLocationDto
@{
    ViewData["Title"] = "CreatePopularLocation";
    Layout = "~/Views/Admin/Index.cshtml";
}

<h1>@ViewData["Title"]</h1>

<div class="bg-light rounded h-100 p-4">
    <form method="post">
        <label>CityName</label>
        <input type="text" asp-for="CityName" class="form-control" />
        <br />
        <label>ImageUrl</label>
        <input type="text" asp-for="ImageUrl" class="form-control" />
        <br />
        <button class="btn btn-primary">Add PopularLocation</button>
    </form>
</div>