@model List<ResultPopularLocationDto>

    @{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Admin/Index.cshtml";
    int counter = 0;
}

<div class="container-fluid pt-4 px-4">
    <div class="row g-4">
        <div class="col-12">
            <div class="bg-light rounded h-100 p-4">
                <h6 class="mb-4">@ViewData["Title"]</h6>
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th scope="col">#</th>
                                <th scope="col">CityName</th>
                                <th scope="col">ImageUrl</th>
                                <th scope="col">Delete</th>
                                <th scope="col">Update</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                counter++;
                                <tr>
                                    <th scope="row">@counter</th>
                                    <td>@item.CityName</td>
                                    <td>@item.ImageUrl</td>
                                    <td><a href="/PopularLocation/DeletePopularLocation/@item.PopularLocationID" class="btn btn-outline-danger">Delete</a></td>
                                    <td><a href="/PopularLocation/UpdatePopularLocation/@item.PopularLocationID" class="btn btn-outline-success">Update</a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    <a href="/PopularLocation/CreatePopularLocation" class="btn btn-outline-info">Enter a new PopularLocation</a>
                </div>
            </div>
        </div>
    </div>
</div>