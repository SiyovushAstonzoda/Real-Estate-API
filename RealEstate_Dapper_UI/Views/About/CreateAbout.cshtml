@model CreateAboutDto
@{
ViewData["Title"] = "CreateAbout";
Layout = "~/Views/Admin/Index.cshtml";
}

<h1>@ViewData["Title"]</h1>

<div class="bg-light rounded h-100 p-4">
    <form method="post">
        <label>Title</label>
        <input type="text" asp-for="Title" class="form-control" />
        <br />
        <label>Subtitle</label>
        <input type="text" asp-for="Subtitle" class="form-control" />
        <br />
        <label>Description1</label>
        <textarea rows="5" asp-for="Description1" class="form-control"></textarea>
        <br />
        <label>Description2</label>
        <textarea rows="5" asp-for="Description2" class="form-control"></textarea>
        <br />
        <button class="btn btn-primary">Add About</button>
    </form>
</div>
</div>
</div>
</div>