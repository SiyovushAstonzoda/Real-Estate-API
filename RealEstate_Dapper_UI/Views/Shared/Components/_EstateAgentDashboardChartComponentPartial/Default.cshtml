@model List<ResultEstateAgentDashboardChartDto>
<!DOCTYPE html>
<html>
<head>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.0"></script>
    <style>
        /* This container forces the charts to sit side-by-side */
        .chart-container {
            display: flex;
            flex-direction: row;
            justify-content: space-around;
            align-items: center;
            gap: 20px; /* Adds a bit of breathing room between the charts */
            flex-wrap: wrap; /* Keeps it responsive; wraps on small mobile screens */
            width: 100%;
        }

        /* Controls the size of each chart wrapper */
        .chart-box {
            flex: 1;
            min-width: 300px; /* Prevents them from getting too squished */
            max-width: 500px;
        }
    </style>
</head>
<body>

<div class="chart-container">
    <div class="chart-box">
        <canvas id="myChart1"></canvas>
    </div>
    <div class="chart-box">
        <canvas id="myChart2"></canvas>
    </div>
</div>

<script>
// --- Chart 1 Configuration ---
const barColors1 = ["rgb(106, 212, 221)", "rgb(127, 199, 217)", "rgb(54, 84, 134)", "rgb(134, 182, 246)", "rgb(0, 141, 218)"];
const ctx1 = document.getElementById('myChart1');

new Chart(ctx1, {
  type: "bar",
  data: {
    labels: @Html.Raw(Json.Serialize(Model.Select(x => x.City))),
    datasets: [{
      backgroundColor: barColors1,
      data: @Html.Raw(Json.Serialize(Model.Select(x => x.CityCount)))
    }]
  },
  options: {
    responsive: true,
    plugins: {
      legend: {display: false},
      title: {
        display: true,
        text: "City - Ad Statistics (Chart 1)",
        font: {size: 16}
      }
    }
  }
});

// --- Chart 2 Configuration ---
const barColors2 = ["rgb(106, 212, 221)", "rgb(127, 199, 217)", "rgb(54, 84, 134)", "rgb(134, 182, 246)", "rgb(0, 141, 218)"];
const ctx2 = document.getElementById('myChart2');

new Chart(ctx2, {
  type: "bar",
  data: {
    labels: @Html.Raw(Json.Serialize(Model.Select(x => x.City))),
    datasets: [{
      backgroundColor: barColors2,
      data: @Html.Raw(Json.Serialize(Model.Select(x => x.CityCount)))
    }]
  },
  options: {
    responsive: true,
    plugins: {
      legend: {display: false},
      title: {
        display: true,
        text: "City - Ad Statistics (Chart 2)",
        font: {size: 16}
      }
    }
  }
});
</script>
</body>
</html>